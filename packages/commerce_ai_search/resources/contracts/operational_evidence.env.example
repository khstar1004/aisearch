# Copy to a protected path such as /etc/haeorum-ai-search/operational-evidence.env
# and replace the values before running collect_operational_evidence.py --env-file.
HAEORUM_PUBLIC_API_KEY=replace-with-public-api-key
HAEORUM_ADMIN_API_KEY=replace-with-admin-key
GEMINI_PROXY_API_KEY=replace-with-internal-gemini-proxy-key
HAEORUM_MSSQL_READONLY_CONNECTION_STRING=DRIVER={ODBC Driver 18 for SQL Server};SERVER=...;DATABASE=...;UID=readonly;PWD=...;Encrypt=yes;TrustServerCertificate=no;ApplicationIntent=ReadOnly
