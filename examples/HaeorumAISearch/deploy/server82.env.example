HAEORUM_ENV=production
HAEORUM_DOCKER_LOG_MAX_SIZE=20m
HAEORUM_DOCKER_LOG_MAX_FILE=5

# Host loopback ports. Apache/Nginx should proxy to HAEORUM_AI_SEARCH_PORT only.
HAEORUM_AI_SEARCH_PORT=8120
MARQO_PORT=8122
GEMINI_EMBEDDING_PORT=8098

HAEORUM_SEARCH_ENGINE=marqo
MARQO_URL=http://marqo-api:8882
HAEORUM_MARQO_MODEL=Marqo/marqo-ecommerce-embeddings-L
HAEORUM_INDEX_NAME=haeorum-products
HAEORUM_ADMIN_API_KEY=replace-with-strong-admin-key

HAEORUM_EMBEDDING_BACKEND=gemini
HAEORUM_GEMINI_EMBEDDING_URL=http://gemini-embedding:8098
HAEORUM_GEMINI_EMBEDDING_PROXY_API_KEY=replace-with-internal-gemini-proxy-key
HAEORUM_GEMINI_EMBEDDING_DIMENSIONS=1536
HAEORUM_GEMINI_MODEL=gemini-embedding-2
GEMINI_AUTH_MODE=api_key
GEMINI_API_KEY=replace-with-protected-gemini-api-key
GEMINI_PROXY_API_KEY=replace-with-internal-gemini-proxy-key
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_EMBEDDING_DIMENSIONS=1536
GEMINI_EMBEDDING_TIMEOUT_SECONDS=90
GEMINI_MAX_RESPONSE_BYTES=33554432
GEMINI_PROXY_MAX_INPUTS_PER_REQUEST=64
GEMINI_PROXY_MAX_CONCURRENT_CALLS=12
GEMINI_PROXY_QUEUE_TIMEOUT_SECONDS=15
GEMINI_PROXY_RATE_LIMIT_RPM=1200
GEMINI_PROXY_RATE_LIMIT_BURST=240

HAEORUM_MALL_CONFIG_PATH=/etc/haeorum-ai-search/malls.json
HAEORUM_QUERY_SYNONYM_PATH=/etc/haeorum-ai-search/query-synonyms.json
HAEORUM_CORS_ORIGINS_FILE=/etc/haeorum-ai-search/cors-origins.txt
HAEORUM_CORS_ORIGINS=

# Use MSSQL in production. Leave HAEORUM_PRODUCT_CSV empty when MSSQL is set.
HAEORUM_PRODUCT_CSV=
HAEORUM_MSSQL_READONLY_CONNECTION_STRING=DRIVER={ODBC Driver 18 for SQL Server};SERVER=replace-with-host;DATABASE=replace-with-db;UID=replace-with-readonly-user;PWD=replace-with-password;Encrypt=yes;TrustServerCertificate=no;ApplicationIntent=ReadOnly
HAEORUM_MSSQL_QUERY=SELECT product_id, product_name, price, price_min, price_max, category_name, print_methods, materials, colors, min_order_qty, delivery_days, product_group_id, main_image_url, product_url, status, updated_at, is_deleted, display_yn, mall_id FROM dbo.v_ai_search_products
HAEORUM_MSSQL_PRODUCT_ID_COLUMN=product_id
HAEORUM_MSSQL_UPDATED_AT_COLUMN=updated_at
HAEORUM_MSSQL_SYNC_FETCH_SIZE=1000
HAEORUM_PRODUCT_URL_TEMPLATE=https://{mall_id}.haeorumgift.com/product_view.asp?p_idx={product_id}
HAEORUM_FILTER_BY_MALL_ID=false

# 8GB server guardrails.
VESPA_MEM_LIMIT=4g
MIOC_MEM_LIMIT=768m
MARQO_API_MEM_LIMIT=768m
GEMINI_PROXY_MEM_LIMIT=512m
HAEORUM_AI_SEARCH_MEM_LIMIT=512m
HAEORUM_REINDEX_MEM_LIMIT=512m
HAEORUM_SYNC_WORKER_MEM_LIMIT=512m
MARQO_API_WORKERS=1
MARQO_MAX_CONCURRENT_SEARCH=24
MARQO_INFERENCE_POOL_SIZE=32
VESPA_POOL_SIZE=32
VESPA_SEARCH_TIMEOUT_MS=5000
MARQO_API_INFERENCE_CACHE_SIZE=32

HAEORUM_SEARCH_MAX_CONCURRENCY=16
HAEORUM_IMAGE_SEARCH_MAX_CONCURRENCY=3
HAEORUM_SEARCH_QUEUE_TIMEOUT_SECONDS=2
HAEORUM_IMAGE_SEARCH_QUEUE_TIMEOUT_SECONDS=2
HAEORUM_API_THREADPOOL_TOKENS=28
HAEORUM_BACKEND_HTTP_MAX_ACTIVE_REQUESTS=24
HAEORUM_SEARCH_RATE_LIMIT_PER_MINUTE=300
HAEORUM_IMAGE_RATE_LIMIT_PER_MINUTE=60
HAEORUM_MALL_SEARCH_RATE_LIMIT_PER_MINUTE=2000
HAEORUM_MALL_IMAGE_RATE_LIMIT_PER_MINUTE=600
HAEORUM_RATE_LIMIT_MAX_BUCKETS=10000
HAEORUM_CACHE_TTL_SECONDS=120
HAEORUM_CACHE_MAX_ENTRIES=5000
HAEORUM_TRUSTED_PROXY_IPS=127.0.0.1,::1,172.16.0.0/12

HAEORUM_MAX_IMAGE_MB=5
HAEORUM_MAX_IMAGE_DIMENSION=1600
HAEORUM_MIN_IMAGE_DIMENSION=16
HAEORUM_VALIDATE_PRODUCT_IMAGES=false
HAEORUM_SYNC_INTERVAL_SECONDS=3600

INSTALL_MSSQL_ODBC=true
ACCEPT_MS_ODBC_EULA=true

