HAEORUM_ENV=production
HAEORUM_SEARCH_ENGINE=marqo
MARQO_URL=http://marqo-api:8882
HAEORUM_MARQO_MODEL=Marqo/marqo-ecommerce-embeddings-L
HAEORUM_MARQO_SEARCH_TIMEOUT_SECONDS=15
HAEORUM_MARQO_SEARCH_RETRY_COUNT=1
HAEORUM_MARQO_SEARCH_RETRY_DELAY_SECONDS=0.1
HAEORUM_BACKEND_RETRY_AFTER_MAX_SECONDS=2
HAEORUM_BACKEND_HTTP_MAX_IDLE_SECONDS=55
HAEORUM_BACKEND_HTTP_MAX_ACTIVE_REQUESTS=96
HAEORUM_BACKEND_HTTP_CONNECTION_ACQUIRE_TIMEOUT_SECONDS=1
HAEORUM_BACKEND_CIRCUIT_FAILURE_THRESHOLD=5
HAEORUM_BACKEND_CIRCUIT_COOLDOWN_SECONDS=5
HAEORUM_BACKEND_CIRCUIT_HALF_OPEN_MAX_CALLS=1
HAEORUM_MARQO_ADD_DOCUMENTS_BATCH_SIZE=128
HAEORUM_MARQO_ADD_DOCUMENTS_MAX_REQUEST_BYTES=8388608
HAEORUM_MARQO_DELETE_DOCUMENTS_BATCH_SIZE=512
MARQO_API_KEEPALIVE_TIMEOUT=75
MARQO_API_GZIP_MINIMUM_SIZE=1024
HAEORUM_GEMINI_QUERY_TIMEOUT_SECONDS=15
HAEORUM_GEMINI_MIXED_QUERY_PARALLELISM=8
HAEORUM_GEMINI_QUERY_RUNTIME_TEXT_CACHE_ENTRIES=2048
HAEORUM_GEMINI_QUERY_RUNTIME_IMAGE_CACHE_ENTRIES=512
HAEORUM_EMBEDDING_BACKEND=gemini
HAEORUM_GEMINI_EMBEDDING_URL=http://gemini-embedding:8098
HAEORUM_GEMINI_EMBEDDING_PROXY_API_KEY=replace-with-internal-gemini-proxy-key
HAEORUM_GEMINI_EMBEDDING_DIMENSIONS=1536
HAEORUM_GEMINI_MODEL=gemini-embedding-2
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_EMBEDDING_DIMENSIONS=1536
GEMINI_EMBEDDING_TIMEOUT_SECONDS=90
GEMINI_MAX_RESPONSE_BYTES=33554432
GEMINI_PROXY_API_KEY=replace-with-internal-gemini-proxy-key
GEMINI_PROXY_MAX_INPUTS_PER_REQUEST=64
GEMINI_PROXY_MAX_CONCURRENT_CALLS=12
GEMINI_PROXY_QUEUE_TIMEOUT_SECONDS=15
GEMINI_PROXY_RATE_LIMIT_RPM=1200
GEMINI_PROXY_RATE_LIMIT_BURST=240
GEMINI_EMBEDDING_PORT=8098
GEMINI_AUTH_MODE=api_key
GEMINI_API_KEY=replace-with-protected-gemini-api-key
# For ADC/OAuth billing, set GEMINI_AUTH_MODE=adc and the billing/quota project.
# GEMINI_QUOTA_PROJECT=replace-with-google-cloud-project-id
HAEORUM_INDEX_NAME=haeorum-products
HAEORUM_ADMIN_API_KEY=replace-with-admin-key
HAEORUM_MALL_CONFIG_PATH=/app/sample_malls.json
HAEORUM_QUERY_SYNONYM_PATH=/app/sample_query_synonyms.json
HAEORUM_CORS_ORIGINS=https://shop001.haeorumgift.com,https://shop002.haeorumgift.com
HAEORUM_PRODUCT_CSV=/app/sample_products.csv
HAEORUM_MSSQL_SYNC_FETCH_SIZE=1000
HAEORUM_PRODUCT_URL_TEMPLATE=https://{mall_id}.haeorumgift.com/product_view.asp?p_idx={product_id}
HAEORUM_FILTER_BY_MALL_ID=false
HAEORUM_MAX_IMAGE_MB=5
HAEORUM_MAX_IMAGE_DIMENSION=1600
HAEORUM_MIN_IMAGE_DIMENSION=16
HAEORUM_IMAGE_VALIDATION_CACHE_TTL_SECONDS=30
HAEORUM_IMAGE_VALIDATION_CACHE_MAX_ENTRIES=32
HAEORUM_MIXED_TEXT_WEIGHT=0.4
HAEORUM_MIXED_IMAGE_WEIGHT=0.6
HAEORUM_TEXT_AUXILIARY_WEIGHT=0.12
HAEORUM_TEXT_AUXILIARY_CANDIDATE_MULTIPLIER=1.0
HAEORUM_TEXT_AUXILIARY_SEARCH_PARALLELISM=8
HAEORUM_LOW_SCORE_THRESHOLD=0.4
HAEORUM_CATEGORY_SUGGESTION_LIMIT=15
# Related-item deep pagination is capped at 500 to bound Marqo candidate fan-out.
HAEORUM_MAX_OFFSET=200
# Keep search/image limits high enough for the required 850 active-user mixed-traffic evidence run.
HAEORUM_SEARCH_RATE_LIMIT_PER_MINUTE=900
HAEORUM_MALL_SEARCH_RATE_LIMIT_PER_MINUTE=2000
HAEORUM_CLICK_RATE_LIMIT_PER_MINUTE=600
HAEORUM_MALL_CLICK_RATE_LIMIT_PER_MINUTE=3000
HAEORUM_IMAGE_RATE_LIMIT_PER_MINUTE=300
HAEORUM_MALL_IMAGE_RATE_LIMIT_PER_MINUTE=600
HAEORUM_RATE_LIMIT_MAX_BUCKETS=10000
HAEORUM_SEARCH_MAX_CONCURRENCY=64
HAEORUM_SEARCH_QUEUE_TIMEOUT_SECONDS=2
HAEORUM_IMAGE_SEARCH_MAX_CONCURRENCY=8
HAEORUM_IMAGE_SEARCH_QUEUE_TIMEOUT_SECONDS=2
HAEORUM_API_GZIP_MINIMUM_SIZE=1024
HAEORUM_CACHE_TTL_SECONDS=30
HAEORUM_CACHE_MAX_ENTRIES=10000
HAEORUM_CACHE_MISS_LOCK_SECONDS=35
HAEORUM_CACHE_MISS_WAIT_SECONDS=5
HAEORUM_CACHE_MISS_POLL_SECONDS=0.05
HAEORUM_REDIS_URL=
HAEORUM_REDIS_KEY_PREFIX=haeorum-ai-search
HAEORUM_REDIS_SOCKET_TIMEOUT_SECONDS=0.5
HAEORUM_REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=0.5
HAEORUM_REDIS_FAILURE_BACKOFF_SECONDS=2
# Trust only the reverse proxy peers that overwrite X-Forwarded-For with $remote_addr.
# If Nginx on the host proxies to a Docker-published API port, include the Docker bridge CIDR.
# Keep the API port firewalled/private so external clients cannot spoof X-Forwarded-For.
HAEORUM_TRUSTED_PROXY_IPS=127.0.0.1,::1,172.16.0.0/12
HAEORUM_SYNC_INTERVAL_SECONDS=3600
HAEORUM_SEARCH_LOG_PATH=/app/logs/search.jsonl
HAEORUM_ERROR_LOG_PATH=/app/logs/error.jsonl
HAEORUM_SYNC_LOG_PATH=/app/logs/sync.jsonl
HAEORUM_LOG_KEEP_OPEN_SECONDS=1
HAEORUM_SYNC_LOCK_STALE_SECONDS=21600
HAEORUM_VALIDATE_PRODUCT_IMAGES=false
HAEORUM_PRODUCT_IMAGE_PROBE_TIMEOUT_SECONDS=10
HAEORUM_PRODUCT_IMAGE_PROBE_RETRY_COUNT=1
HAEORUM_PRODUCT_IMAGE_PROBE_RETRY_DELAY_SECONDS=0.25
HAEORUM_PRODUCT_IMAGE_DOWNLOAD_THREAD_COUNT=3
HAEORUM_SYNC_ALERT_WEBHOOK_URL=
HAEORUM_SYNC_ALERT_TIMEOUT_SECONDS=5

# Docker build only. Set both true when this image must connect to MSSQL directly.
INSTALL_MSSQL_ODBC=false
ACCEPT_MS_ODBC_EULA=false

# MSSQL 운영 연동 시 CSV 대신 아래 값을 설정합니다.
# HAEORUM_MSSQL_READONLY_CONNECTION_STRING=DRIVER={ODBC Driver 18 for SQL Server};SERVER=...;DATABASE=...;UID=readonly;PWD=...;Encrypt=yes;TrustServerCertificate=no;ApplicationIntent=ReadOnly
# HAEORUM_MSSQL_QUERY=SELECT product_id, product_name, price, category_name, main_image_url, product_url, status, updated_at, is_deleted, display_yn, mall_id FROM dbo.v_ai_search_products
# HAEORUM_MSSQL_PRODUCT_ID_COLUMN=product_id
# HAEORUM_MSSQL_UPDATED_AT_COLUMN=updated_at
