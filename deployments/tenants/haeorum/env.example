HAEORUM_ENV=production
HAEORUM_SEARCH_ENGINE=marqo
MARQO_URL=http://marqo-api:8882
HAEORUM_MARQO_MODEL=Marqo/marqo-ecommerce-embeddings-L
HAEORUM_INDEX_NAME=haeorum-products
HAEORUM_ADMIN_API_KEY=replace-with-strong-admin-key

HAEORUM_EMBEDDING_BACKEND=gemini
HAEORUM_GEMINI_EMBEDDING_URL=http://embedding-service:8098
HAEORUM_GEMINI_EMBEDDING_PROXY_API_KEY=replace-with-internal-gemini-proxy-key
GEMINI_PROXY_API_KEY=replace-with-internal-gemini-proxy-key
HAEORUM_GEMINI_EMBEDDING_DIMENSIONS=1536
HAEORUM_GEMINI_MODEL=gemini-embedding-2

HAEORUM_MALL_CONFIG_PATH=/etc/haeorum-ai-search/malls.json
HAEORUM_QUERY_SYNONYM_PATH=/etc/haeorum-ai-search/query-synonyms.json
HAEORUM_CORS_ORIGINS_FILE=/etc/haeorum-ai-search/cors-origins.txt
HAEORUM_PRODUCT_URL_TEMPLATE=https://{mall_id}.haeorumgift.com/product_view.asp?p_idx={product_id}
HAEORUM_FILTER_BY_MALL_ID=false

HAEORUM_MSSQL_READONLY_CONNECTION_STRING=DRIVER={ODBC Driver 18 for SQL Server};SERVER=replace-with-host;DATABASE=replace-with-db;UID=readonly;PWD=replace-with-password;Encrypt=yes;TrustServerCertificate=no;ApplicationIntent=ReadOnly
HAEORUM_MSSQL_QUERY=replace-with-readonly-select-or-use-env-file-loader
HAEORUM_MSSQL_PRODUCT_ID_COLUMN=product_id
HAEORUM_MSSQL_UPDATED_AT_COLUMN=updated_at
HAEORUM_MSSQL_SYNC_FETCH_SIZE=1000
HAEORUM_SYNC_INTERVAL_SECONDS=3600

HAEORUM_SEARCH_LOG_PATH=/var/log/haeorum-ai-search/search.jsonl
HAEORUM_ERROR_LOG_PATH=/var/log/haeorum-ai-search/error.jsonl
HAEORUM_SYNC_LOG_PATH=/var/log/haeorum-ai-search/sync.jsonl
HAEORUM_REDIS_URL=
HAEORUM_REDIS_KEY_PREFIX=haeorum-ai-search

