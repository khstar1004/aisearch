<?xml version="1.0" encoding="UTF-8"?>
<?mso-application progid="Excel.Sheet"?>
<Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet"
 xmlns:o="urn:schemas-microsoft-com:office:office"
 xmlns:x="urn:schemas-microsoft-com:office:excel"
 xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet">
  <Styles>
    <Style ss:ID="Title"><Font ss:Bold="1" ss:Size="14"/><Alignment ss:WrapText="1"/></Style>
    <Style ss:ID="Header"><Font ss:Bold="1"/><Interior ss:Color="#D9EAF7" ss:Pattern="Solid"/><Alignment ss:WrapText="1" ss:Vertical="Top"/></Style>
    <Style ss:ID="Wrap"><Alignment ss:WrapText="1" ss:Vertical="Top"/></Style>
  </Styles>
  <Worksheet ss:Name="마케팅전략">
    <Table>
      <Column ss:Width="170"/><Column ss:Width="360"/><Column ss:Width="210"/><Column ss:Width="260"/>
      <Row><Cell ss:StyleID="Title"><Data ss:Type="String">AI 검색 기능 상품화 및 영업 전략</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">작성일: 2026-06-02 / 검색 기반 1차 영업 리스트. 웹 전체의 완전 크롤링을 보장하지 않음.</Data></Cell></Row>
      <Row>
        <Cell ss:StyleID="Header"><Data ss:Type="String">항목</Data></Cell>
        <Cell ss:StyleID="Header"><Data ss:Type="String">전략</Data></Cell>
        <Cell ss:StyleID="Header"><Data ss:Type="String">실행 방식</Data></Cell>
        <Cell ss:StyleID="Header"><Data ss:Type="String">메모</Data></Cell>
      </Row>
      <Row><Cell ss:StyleID="Wrap"><Data ss:Type="String">핵심 포지셔닝</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">상품명을 몰라도 목적, 예산, 대상, 납기, 인쇄 조건으로 원하는 상품을 찾게 해주는 쇼핑몰용 AI 상품 검색/추천 엔진.</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">해오름기프트 사례를 데모로 사용. "텀블러"가 아니라 "관공서 행사 300개, 1만원대, 로고 인쇄 가능한 실용품" 같은 검색을 보여준다.</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">판촉물은 카탈로그가 크고 고객 의도가 모호해서 가장 좋은 첫 시장.</Data></Cell></Row>
      <Row><Cell ss:StyleID="Wrap"><Data ss:Type="String">1차 타깃</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">국내 판촉물, 기념품, 기업 답례품, 굿즈 제작 쇼핑몰.</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">검색 품질 진단 리포트 무료 제공 후 2주 파일럿 제안.</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">상품 수, 옵션, 인쇄 조건, 최소 주문 수량이 복잡해 AI 검색의 가치가 바로 보임.</Data></Cell></Row>
      <Row><Cell ss:StyleID="Wrap"><Data ss:Type="String">2차 타깃</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">B2B 도매, MRO/산업재, 사무용품, 전자부품, 패션 도매, 뷰티/건강식품 도매.</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">카탈로그 검색 실패율, 무검색 전환율, 동의어/규격 검색 문제를 지표화한다.</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">B2B는 검색 실패가 곧 견적 문의 이탈이라 ROI 설명이 쉽다.</Data></Cell></Row>
      <Row><Cell ss:StyleID="Wrap"><Data ss:Type="String">3차 타깃</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">일반 전문몰: 리빙, 문구, 펫, 캠핑, 자동차용품, 의료/위생용품, 선물 큐레이션몰.</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">카테고리별 자연어 검색과 상품 추천 위젯으로 랜딩.</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">대형 종합몰보다 중견 전문몰이 구매 의사결정이 빠름.</Data></Cell></Row>
      <Row><Cell ss:StyleID="Wrap"><Data ss:Type="String">구매자 페르소나</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">대표, 이커머스 팀장, 상품기획/MD, 마케팅팀, 개발 외주사/SI.</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">대표에게는 매출/문의 전환, MD에게는 상품 탐색 효율, 개발팀에는 빠른 연동과 운영 부담 감소를 강조.</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">초기 영업은 대표/이커머스 책임자에게 직접 접근.</Data></Cell></Row>
      <Row><Cell ss:StyleID="Wrap"><Data ss:Type="String">제품 패키지</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">Search Audit, Pilot, Managed Search, Enterprise API 4단계로 판다.</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">Audit: 3일 리포트 / Pilot: 2주 연동 / Managed: 월 구독 / Enterprise: API와 커스텀 랭킹.</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">처음부터 큰 프로젝트로 팔지 말고 작은 진단과 파일럿으로 들어간다.</Data></Cell></Row>
      <Row><Cell ss:StyleID="Wrap"><Data ss:Type="String">가격 제안</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">초기 구축비 + 월 구독료 + 선택형 성과 보너스.</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">예: 진단 무료 또는 50만원, 파일럿 200만~500만원, 운영 월 100만~500만원, 대형몰 별도 견적.</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">초기 시장에서는 구축비를 낮추고 월 운영/개선 계약을 확보.</Data></Cell></Row>
      <Row><Cell ss:StyleID="Wrap"><Data ss:Type="String">핵심 데모 검색어</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">"개업 답례품 200개 5천원대", "병원 홍보물 위생적이고 고급스러운 것", "로고 인쇄 가능한 친환경 굿즈", "학교 행사 예산 100만원".</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">기존 키워드 검색과 AI 검색 결과를 나란히 보여준다.</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">검색 로그 기반 추천, 오타/동의어, 필터 추론까지 시연.</Data></Cell></Row>
      <Row><Cell ss:StyleID="Wrap"><Data ss:Type="String">영업 메시지</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">"상품이 많은 쇼핑몰일수록 고객은 검색어를 틀립니다. AI 검색은 고객의 말에서 목적과 조건을 읽어 상품을 바로 좁혀줍니다."</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">사이트 10개 검색 테스트 스크린샷을 만들어 콜드메일에 첨부.</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">상대 사이트를 실제로 검색해본 근거가 있어야 응답률이 올라감.</Data></Cell></Row>
      <Row><Cell ss:StyleID="Wrap"><Data ss:Type="String">차별화 포인트</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">한국어 자연어, 예산/수량/납기/대상 추론, 상품 속성 정규화, 기존 쇼핑몰 연동, 검색 로그 리포트.</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">네이버/구글 검색이 아니라 사이트 내부 상품 검색 전환율을 개선한다고 설명.</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">판촉물 특화 용어 사전과 카테고리 매핑을 강조.</Data></Cell></Row>
      <Row><Cell ss:StyleID="Wrap"><Data ss:Type="String">검증 지표</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">검색 후 상품 클릭률, 검색 후 문의/장바구니 전환율, 무결과 검색률, 상담 문의 감소, 평균 탐색 시간.</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">파일럿 전 2주, 파일럿 후 2주로 비교.</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">매출 직접 귀속이 어려우면 검색 전환/문의 전환을 선행 지표로 둔다.</Data></Cell></Row>
      <Row><Cell ss:StyleID="Wrap"><Data ss:Type="String">채널 전략</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">직접 영업 70%, 쇼핑몰 제작사/카페24 파트너/SI 제휴 20%, 콘텐츠/SEO 10%.</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">"판촉물 AI 검색", "쇼핑몰 검색 개선", "B2B 상품검색" 랜딩페이지 운영.</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">초기에는 제휴보다 직접 성공 사례 확보가 우선.</Data></Cell></Row>
      <Row><Cell ss:StyleID="Wrap"><Data ss:Type="String">30일 액션</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">국내 판촉물 30개 사이트 검색 품질 점검, 데모 영상 제작, 콜드메일 100건 발송.</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">상위 10개는 직접 전화 후 메일 재발송.</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">메일 제목은 사이트별 검색 실패 사례를 넣는다.</Data></Cell></Row>
      <Row><Cell ss:StyleID="Wrap"><Data ss:Type="String">60일 액션</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">파일럿 3곳 확보, 검색 로그 기반 개선 리포트 작성, 국내 B2B/전문몰로 확장.</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">파일럿 계약서에는 운영 전환 가격을 미리 명시.</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">무료 PoC 장기화를 막는다.</Data></Cell></Row>
      <Row><Cell ss:StyleID="Wrap"><Data ss:Type="String">90일 액션</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">유료 운영 2곳 이상, 레퍼런스 1건 공개, 쇼핑몰 제작사 3곳과 리셀러 논의.</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">레퍼런스는 전환율보다 "검색 실패 감소"와 "상담 효율"부터 공개.</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">해외 판촉물 시장은 영어 데모와 파트너십으로 접근.</Data></Cell></Row>
    </Table>
  </Worksheet>
  <Worksheet ss:Name="리드_전체">
    <Table>
      <Column ss:Width="35"/><Column ss:Width="75"/><Column ss:Width="130"/><Column ss:Width="180"/><Column ss:Width="210"/><Column ss:Width="220"/><Column ss:Width="260"/><Column ss:Width="70"/><Column ss:Width="300"/><Column ss:Width="220"/>
      <Row>
        <Cell ss:StyleID="Header"><Data ss:Type="String">No</Data></Cell>
        <Cell ss:StyleID="Header"><Data ss:Type="String">지역</Data></Cell>
        <Cell ss:StyleID="Header"><Data ss:Type="String">구분</Data></Cell>
        <Cell ss:StyleID="Header"><Data ss:Type="String">사이트/회사</Data></Cell>
        <Cell ss:StyleID="Header"><Data ss:Type="String">URL</Data></Cell>
        <Cell ss:StyleID="Header"><Data ss:Type="String">타깃 적합성</Data></Cell>
        <Cell ss:StyleID="Header"><Data ss:Type="String">AI 검색 도입 포인트</Data></Cell>
        <Cell ss:StyleID="Header"><Data ss:Type="String">우선순위</Data></Cell>
        <Cell ss:StyleID="Header"><Data ss:Type="String">첫 제안 메시지</Data></Cell>
        <Cell ss:StyleID="Header"><Data ss:Type="String">출처/메모</Data></Cell>
      </Row>
      <Row><Cell><Data ss:Type="Number">1</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">한국</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">레퍼런스</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">해오름기프트</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">기존 구축 사례</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">판촉물 검색 데모 기준점</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">기존 성공 사례로 영업 설득에 사용</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">A</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">해오름기프트형 AI 검색을 귀사 상품 카탈로그에 맞춰 빠르게 붙일 수 있습니다.</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">내부 레퍼런스</Data></Cell></Row>
      <Row><Cell><Data ss:Type="Number">2</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">한국</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">판촉물 전문몰</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">고려기프트</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">https://koreagift.com</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">대형 온라인 판촉물 플랫폼</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">상품명/용도/예산/브랜드 검색을 통합하면 탐색 시간이 줄어듦</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">A</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">상품 수가 많은 온라인 판촉물몰일수록 AI 검색의 무결과 감소 효과가 큽니다.</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">기프트비교 비교 대상 및 공식 소개 확인</Data></Cell></Row>
      <Row><Cell><Data ss:Type="Number">3</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">한국</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">판촉물 전문몰</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">세종기프트/기프트인포</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">https://giftinfo.co.kr</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">대형 판촉물 제조/유통 기업</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">최다상품, 자체 제작, 공공기관 구매 조건을 검색 의도에 반영</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">A</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">공공기관/기업 구매자가 자연어로 조건을 말하면 적합 상품군을 바로 좁혀주는 검색을 제안합니다.</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">사람인 기업정보에서 홈페이지 확인</Data></Cell></Row>
      <Row><Cell><Data ss:Type="Number">4</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">한국</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">판촉물 전문몰</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">판촉사랑</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">https://prglobal.co.kr</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">국내 주요 판촉물/기념품 쇼핑몰</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">카테고리 폭이 넓고 브랜드 상품이 많아 의미 기반 검색 적합</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">A</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">AI 업종별 추천을 검색창과 연결하면 고객이 더 빠르게 상품을 고르게 됩니다.</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">공식 사이트 및 87sarang 기업정보 확인</Data></Cell></Row>
      <Row><Cell><Data ss:Type="Number">5</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">한국</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">판촉물 전문몰</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">기프트조아</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">https://giftjoa.com</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">여러 판촉물 쇼핑몰 운영 허브</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">복수 쇼핑몰의 상품/가격/인기 데이터를 하나의 AI 검색으로 묶을 수 있음</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">A</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">4개 쇼핑몰 운영 구조에 통합 AI 검색/추천 레이어를 붙이면 계열몰 전체에 재사용 가능합니다.</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">공식 페이지에서 4개 쇼핑몰 운영 확인</Data></Cell></Row>
      <Row><Cell><Data ss:Type="Number">6</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">한국</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">판촉물 전문몰</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">기프트조아코리아</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">https://giftjoa.co.kr</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">대표 판촉물 쇼핑몰</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">학교/관공서 납품 조건 검색과 추천</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">A</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">기관 구매자용 검색어를 상품 속성으로 번역하는 AI 검색을 제안합니다.</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">기프트조아 공식 페이지 연결 쇼핑몰</Data></Cell></Row>
